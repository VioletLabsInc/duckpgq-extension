# name: test/sql/path_finding/path_length_bounded_nested_production.test
# description: production related_entities query shape without leading dash prefix
# group: [path_finding]

require duckpgq

statement ok
CREATE TABLE Student(id BIGINT, name VARCHAR);
INSERT INTO Student VALUES (0, 'Daniel'), (1, 'Tavneet'), (2, 'Gabor'), (3, 'Peter'), (4, 'David');

statement ok
CREATE TABLE know(src BIGINT, dst BIGINT, id BIGINT);
INSERT INTO know VALUES (0,1, 10), (0,2, 11), (0,3, 12), (3,0, 13), (1,2, 14), (1,3, 15), (2,3, 16), (4,3, 17), (2, 4, 18);

statement ok
-CREATE PROPERTY GRAPH pg
VERTEX TABLES (
    Student
    )
EDGE TABLES (
    know   SOURCE KEY (src) REFERENCES Student (id)
                DESTINATION KEY (dst) REFERENCES Student (id)
    );

query III
SELECT DISTINCT
    entity_id,
    name,
    hop_distance
FROM (
    FROM GRAPH_TABLE(pg
        MATCH p = (a:Student WHERE a.id = 0)-[e:know]-{1,3}(b:Student WHERE b.id > 0)
        COLUMNS (
            b.id AS entity_id,
            COALESCE(b.name, 'unknown') AS name,
            path_length(p) AS hop_distance
        )
    )
) g
ORDER BY hop_distance, name
LIMIT 500;
----
2	Gabor	1
3	Peter	1
1	Tavneet	1
4	David	2
